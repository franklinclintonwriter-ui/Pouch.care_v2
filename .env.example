# ----------------------------------------------------------------------------
# Pouch Care International Ltd. — Environment Variables (EXAMPLE)
# Copy this file to `.env.local` and fill in real values. NEVER commit secrets.
# ----------------------------------------------------------------------------

# Canonical public site URL (used for SEO metadata, sitemap, canonical tags).
NEXT_PUBLIC_SITE_URL=https://www.pouchcare.com

# Public organisation contact endpoint (optional). Used only for display.
NEXT_PUBLIC_CONTACT_EMAIL=info@pouchcare.com

# Optional: form submission endpoint for contact/careers (server action target).
# Leave blank to keep forms in safe UI-only placeholder mode.
CONTACT_FORM_ENDPOINT=

# Optional: analytics measurement id (leave blank to disable).
NEXT_PUBLIC_ANALYTICS_ID=
